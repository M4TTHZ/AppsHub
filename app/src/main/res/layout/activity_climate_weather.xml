<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".ClimateWeather.ClimateWeatherActivity">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ClimaApp"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Campo de Busca -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="#2196F3"
        app:hintTextColor="#2196F3"
        android:hint="Digite o nome da cidade">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCidadeNome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLength="50"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botão Buscar -->
    <Button
        android:id="@+id/btnBuscarCidade"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Buscar"
        android:textAllCaps="false"
        android:backgroundTint="#2196F3" />

    <!-- ProgressBar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Mensagem de Erro -->
    <TextView
        android:id="@+id/tvErro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="12dp"
        android:textSize="14sp"
        android:textColor="#F44336"
        android:visibility="gone" />

    <!-- Container de Resultados -->
    <LinearLayout
        android:id="@+id/layoutResultados"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="32dp"
        android:elevation="4dp"
        android:layout_marginTop="16dp"
        android:visibility="gone">

        <!-- Temperatura -->
        <TextView
            android:id="@+id/tvGraus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="--°C"
            android:textSize="72sp"
            android:textStyle="bold"
            android:textColor="#FF6B35"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Condição do Clima -->
        <TextView
            android:id="@+id/tvClima"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="16dp" />

        <!-- Vento -->
        <TextView
            android:id="@+id/tvVento"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vento: -- km/h"
            android:textSize="16sp"
            android:gravity="center"
            android:textColor="#666666" />

    </LinearLayout>

    <!-- Mensagem de Instrução -->
    <TextView
        android:id="@+id/tvInstrucao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Digite o nome de uma cidade para ver o clima"
        android:textSize="14sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:visibility="visible" />

</LinearLayout>